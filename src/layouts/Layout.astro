---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "120 ridiculously creative homework excuses, rated by absurdity." } = Astro.props;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/explore', label: 'Explore' },
  { href: '/categories', label: 'Categories' },
  { href: '/about', label: 'About' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="flex flex-col min-h-screen">
    <nav class="sticky top-0 z-50 bg-bg/80 backdrop-blur-xl backdrop-saturate-150 border-b border-separator/50">
      <div class="max-w-[980px] mx-auto px-5 sm:px-6">
        <div class="flex items-center justify-between h-14 sm:h-12">
          <a href="/" class="text-fg text-base sm:text-sm font-semibold tracking-tight hover:text-fg-secondary transition-colors">
            It's Ridiculous
          </a>

          <div class="hidden md:flex items-center gap-7">
            {navLinks.map(link => (
              <a
                href={link.href}
                class:list={[
                  'text-xs transition-colors',
                  currentPath === link.href
                    ? 'text-fg font-medium'
                    : 'text-fg-secondary hover:text-fg'
                ]}
              >
                {link.label}
              </a>
            ))}
          </div>

          <button
            id="mobile-menu-btn"
            class="md:hidden p-2 -mr-2 text-fg-secondary hover:text-fg transition-colors"
            aria-label="Toggle menu"
          >
            <svg id="menu-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg id="menu-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>

      <div id="mobile-menu" class="hidden md:hidden border-t border-separator/50">
        <div class="max-w-[980px] mx-auto px-5 py-2">
          {navLinks.map(link => (
            <a
              href={link.href}
              class:list={[
                'block py-4 text-base border-b border-separator/30 last:border-0 transition-colors',
                currentPath === link.href
                  ? 'text-fg font-medium'
                  : 'text-fg-secondary'
              ]}
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </nav>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-separator/50 mt-12">
      <div class="max-w-[980px] mx-auto px-5 sm:px-6 py-5">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-fg-tertiary">
          <span>It's Ridiculous</span>
          <a
            href="https://github.com/MichalZak17/Its-Ridiculous-API"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-fg-secondary transition-colors"
          >
            View API on GitHub
          </a>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      const iconOpen = document.getElementById('menu-open');
      const iconClose = document.getElementById('menu-close');

      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
        iconOpen?.classList.toggle('hidden');
        iconClose?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
