---
interface Props {
  id: number;
  excuse: string;
  ridiculous_rating: number;
  category: string;
  will_work: boolean;
  teacher_reaction: string;
}

const { id, excuse, ridiculous_rating, category, will_work, teacher_reaction } = Astro.props;
---

<article class="group border-b border-separator/40 py-7 sm:py-6 first:pt-0 last:border-0">
  <div class="flex items-start justify-between gap-4 mb-3">
    <div class="flex items-center gap-3">
      <span class="text-xs sm:text-[11px] font-medium uppercase tracking-widest text-fg-tertiary">{category}</span>
      <span class="text-separator">·</span>
      <span class="text-xs sm:text-[11px] text-fg-tertiary font-mono">#{id}</span>
    </div>
    <button
      class="copy-btn sm:opacity-0 sm:group-hover:opacity-100 sm:focus:opacity-100 transition-opacity text-fg-tertiary hover:text-fg text-sm sm:text-xs flex items-center gap-1.5 cursor-pointer shrink-0"
      data-excuse={excuse}
      aria-label="Copy excuse"
    >
      <svg class="w-5 h-5 sm:w-3.5 sm:h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
      </svg>
      <span class="copy-label">Copy</span>
    </button>
  </div>

  <p class="text-lg sm:text-base text-fg font-medium leading-relaxed tracking-tight mb-4">
    {excuse}
  </p>

  <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm sm:text-[13px] mb-4">
    <span class="text-fg-secondary">
      Absurdity <span class="text-fg font-medium">{ridiculous_rating}/10</span>
    </span>
    <span class={will_work ? 'text-success' : 'text-danger'}>
      {will_work ? 'Might work' : 'Won\'t work'}
    </span>
  </div>

  <p class="text-base sm:text-sm text-fg-secondary italic leading-relaxed">
    Teacher: "{teacher_reaction}"
  </p>
</article>

<script>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const excuse = (btn as HTMLElement).dataset.excuse;
      if (!excuse) return;
      try {
        await navigator.clipboard.writeText(excuse);
        const label = btn.querySelector('.copy-label');
        if (label) {
          label.textContent = 'Copied';
          setTimeout(() => { label.textContent = 'Copy'; }, 1500);
        }
      } catch {}
    });
  });
</script>
