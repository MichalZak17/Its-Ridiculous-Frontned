---
import excusesData from '../data/excuses.json';
const allExcuses = excusesData.excuses;
---

<div id="random-section" class="w-full">
  <div class="text-center mb-8 sm:mb-10">
    <button id="random-btn" class="inline-flex items-center gap-2 px-6 py-3 sm:px-5 sm:py-2.5 bg-accent text-white text-base sm:text-sm font-medium rounded-full hover:bg-accent-hover active:scale-[0.97] transition-all cursor-pointer">
      Generate Excuse
    </button>
  </div>

  <div id="excuse-container" class="max-w-2xl mx-auto">
    <div id="excuse-placeholder" class="text-center py-10">
      <p class="text-fg-tertiary text-base sm:text-sm">Press the button to get a random excuse.</p>
    </div>

    <div id="excuse-result" class="hidden"></div>
  </div>
</div>

<script define:vars={{ allExcuses }}>
  window.__excuses = allExcuses;
</script>

<script>
  const excuses = (window as any).__excuses as any[];

  const btn = document.getElementById('random-btn');
  const placeholder = document.getElementById('excuse-placeholder');
  const result = document.getElementById('excuse-result');

  function escapeHtml(s: string) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function renderExcuse(data: any) {
    if (!result) return;
    placeholder?.classList.add('hidden');
    result.classList.remove('hidden');

    result.innerHTML = `
      <div class="animate-fade-in">
        <div class="flex items-center justify-between mb-3">
          <div class="flex items-center gap-3">
            <span class="text-xs sm:text-[11px] font-medium uppercase tracking-widest text-fg-tertiary">${escapeHtml(data.category)}</span>
            <span class="text-separator">&middot;</span>
            <span class="text-xs sm:text-[11px] text-fg-tertiary" style="font-family:var(--font-mono)">#${data.id}</span>
          </div>
          <button
            id="copy-random"
            class="text-fg-tertiary hover:text-fg text-sm sm:text-xs flex items-center gap-1.5 cursor-pointer transition-colors shrink-0"
          >
            <svg class="w-5 h-5 sm:w-3.5 sm:h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
            <span id="copy-random-label">Copy</span>
          </button>
        </div>

        <p class="text-xl sm:text-2xl text-fg font-semibold leading-snug tracking-tight mb-5">
          ${escapeHtml(data.excuse)}
        </p>

        <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm sm:text-[13px] mb-5">
          <span class="text-fg-secondary">
            Absurdity <span class="text-fg font-medium">${data.ridiculous_rating}/10</span>
          </span>
          <span class="${data.will_work ? 'text-success' : 'text-danger'}">
            ${data.will_work ? 'Might work' : 'Won\'t work'}
          </span>
        </div>

        <p class="text-base sm:text-sm text-fg-secondary italic leading-relaxed">
          Teacher: &ldquo;${escapeHtml(data.teacher_reaction)}&rdquo;
        </p>

        <div class="mt-7 pt-6 border-t border-separator/30 text-center">
          <button id="random-btn-again" class="text-accent hover:text-accent-hover text-base sm:text-sm font-medium cursor-pointer transition-colors">
            Try another
          </button>
        </div>
      </div>
    `;

    document.getElementById('copy-random')?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(data.excuse);
        const label = document.getElementById('copy-random-label');
        if (label) { label.textContent = 'Copied'; setTimeout(() => { label.textContent = 'Copy'; }, 1500); }
      } catch {}
    });

    document.getElementById('random-btn-again')?.addEventListener('click', generate);
  }

  function generate() {
    const idx = Math.floor(Math.random() * excuses.length);
    renderExcuse(excuses[idx]);
  }

  btn?.addEventListener('click', generate);
</script>
