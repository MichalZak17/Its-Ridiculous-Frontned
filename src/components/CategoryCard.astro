---
interface Props {
  category: string;
  description: string;
}

const { category, description } = Astro.props;
---

<a
  href={`/explore?category=${category}`}
  class="block py-5 sm:py-4 border-b border-separator/30 last:border-0 group transition-colors"
>
  <div class="flex items-center justify-between gap-4">
    <div>
      <h3 class="text-fg font-medium capitalize text-lg sm:text-[15px] group-hover:text-accent transition-colors">{category}</h3>
      <p class="text-fg-tertiary text-sm sm:text-[13px] mt-1 sm:mt-0.5">{description}</p>
    </div>
    <svg class="w-5 h-5 sm:w-4 sm:h-4 text-fg-tertiary group-hover:text-accent group-hover:translate-x-0.5 transition-all shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7" />
    </svg>
  </div>
</a>
