---
import Layout from '../layouts/Layout.astro';
import excusesData from '../data/excuses.json';

const allExcuses = excusesData.excuses;
const categories = excusesData.categories;
---

<Layout title="Explore Excuses — It's Ridiculous">
  <section class="px-5 sm:px-6 py-8 sm:py-12">
    <div class="max-w-[980px] mx-auto">
      <h1 id="page-title" class="font-display text-3xl sm:text-4xl font-bold text-fg tracking-tight mb-1">
        All excuses.
      </h1>
      <p id="page-subtitle" class="text-fg-secondary text-base sm:text-sm mb-8"></p>

      <!-- Filters -->
      <div class="mb-8 overflow-x-auto -mx-5 px-5 sm:mx-0 sm:px-0">
        <div id="filters" class="flex gap-2 pb-2 min-w-max sm:flex-wrap sm:min-w-0"></div>
      </div>

      <!-- Excuse list -->
      <div id="excuses-list"></div>

      <!-- Pagination -->
      <nav id="pagination" class="hidden items-center justify-center gap-5 text-base sm:text-sm mt-10">
        <button id="prev-btn" class="text-accent hover:text-accent-hover disabled:text-fg-tertiary disabled:cursor-not-allowed transition-colors cursor-pointer font-medium">Previous</button>
        <span id="page-info" class="text-fg-tertiary text-sm sm:text-xs"></span>
        <button id="next-btn" class="text-accent hover:text-accent-hover disabled:text-fg-tertiary disabled:cursor-not-allowed transition-colors cursor-pointer font-medium">Next</button>
      </nav>
    </div>
  </section>
</Layout>

<script define:vars={{ allExcuses, categories }}>
  window.__excuses = allExcuses;
  window.__categories = categories;
</script>

<script>
  const excuses = (window as any).__excuses as any[];
  const categories = (window as any).__categories as string[];
  const PER_PAGE = 12;

  const titleEl = document.getElementById('page-title')!;
  const subtitleEl = document.getElementById('page-subtitle')!;
  const filtersEl = document.getElementById('filters')!;
  const listEl = document.getElementById('excuses-list')!;
  const paginationEl = document.getElementById('pagination')!;
  const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
  const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
  const pageInfo = document.getElementById('page-info')!;

  let currentCategory = new URLSearchParams(window.location.search).get('category') || '';
  let currentPage = 1;

  function escapeHtml(s: string) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function getFiltered() {
    return currentCategory ? excuses.filter(e => e.category === currentCategory) : excuses;
  }

  function renderFilters() {
    filtersEl.innerHTML = '';

    const mkBtn = (label: string, cat: string, active: boolean) => {
      const el = document.createElement('button');
      el.textContent = label;
      el.className = active
        ? 'px-4 py-2 sm:px-3 sm:py-1.5 rounded-full text-sm sm:text-xs font-medium bg-fg text-bg cursor-pointer transition-colors whitespace-nowrap'
        : 'px-4 py-2 sm:px-3 sm:py-1.5 rounded-full text-sm sm:text-xs font-medium text-fg-secondary bg-bg-elevated hover:text-fg cursor-pointer transition-colors whitespace-nowrap';
      el.addEventListener('click', () => { currentCategory = cat; currentPage = 1; render(); updateUrl(); });
      filtersEl.appendChild(el);
    };

    mkBtn('All', '', !currentCategory);
    categories.forEach(cat => mkBtn(cat.charAt(0).toUpperCase() + cat.slice(1), cat, currentCategory === cat));
  }

  function renderExcuseHtml(data: any): string {
    return `
      <article class="group border-b border-separator/40 py-7 sm:py-6 first:pt-0 last:border-0 animate-fade-in">
        <div class="flex items-start justify-between gap-4 mb-3">
          <div class="flex items-center gap-3">
            <span class="text-xs sm:text-[11px] font-medium uppercase tracking-widest text-fg-tertiary">${escapeHtml(data.category)}</span>
            <span class="text-separator">&middot;</span>
            <span class="text-xs sm:text-[11px] text-fg-tertiary" style="font-family:var(--font-mono)">#${data.id}</span>
          </div>
          <button
            class="excuse-copy sm:opacity-0 sm:group-hover:opacity-100 sm:focus:opacity-100 transition-opacity text-fg-tertiary hover:text-fg text-sm sm:text-xs flex items-center gap-1.5 cursor-pointer shrink-0"
            data-text="${escapeHtml(data.excuse)}"
          >
            <svg class="w-5 h-5 sm:w-3.5 sm:h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
            <span class="copy-label">Copy</span>
          </button>
        </div>
        <p class="text-lg sm:text-base text-fg font-medium leading-relaxed tracking-tight mb-4">${escapeHtml(data.excuse)}</p>
        <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm sm:text-[13px] mb-4">
          <span class="text-fg-secondary">Absurdity <span class="text-fg font-medium">${data.ridiculous_rating}/10</span></span>
          <span class="${data.will_work ? 'text-success' : 'text-danger'}">${data.will_work ? 'Might work' : 'Won\'t work'}</span>
        </div>
        <p class="text-base sm:text-sm text-fg-secondary italic leading-relaxed">Teacher: &ldquo;${escapeHtml(data.teacher_reaction)}&rdquo;</p>
      </article>
    `;
  }

  function bindCopy() {
    document.querySelectorAll('.excuse-copy').forEach(btn => {
      btn.addEventListener('click', async () => {
        const text = (btn as HTMLElement).dataset.text;
        if (!text) return;
        try {
          await navigator.clipboard.writeText(text);
          const label = btn.querySelector('.copy-label');
          if (label) { label.textContent = 'Copied'; setTimeout(() => { label.textContent = 'Copy'; }, 1500); }
        } catch {}
      });
    });
  }

  function updateUrl() {
    const params = new URLSearchParams();
    if (currentCategory) params.set('category', currentCategory);
    if (currentPage > 1) params.set('page', String(currentPage));
    const qs = params.toString();
    history.replaceState(null, '', qs ? `?${qs}` : '/explore');
  }

  function render() {
    const filtered = getFiltered();
    const total = filtered.length;
    const totalPages = Math.ceil(total / PER_PAGE);
    const start = (currentPage - 1) * PER_PAGE;
    const pageExcuses = filtered.slice(start, start + PER_PAGE);

    titleEl.textContent = currentCategory
      ? `${currentCategory.charAt(0).toUpperCase() + currentCategory.slice(1)} excuses.`
      : 'All excuses.';
    subtitleEl.textContent = `${total} excuse${total !== 1 ? 's' : ''}`;

    renderFilters();

    if (pageExcuses.length === 0) {
      listEl.innerHTML = '<p class="text-center text-fg-tertiary text-base sm:text-sm py-10">No excuses found.</p>';
      paginationEl.classList.add('hidden');
      return;
    }

    listEl.innerHTML = pageExcuses.map(renderExcuseHtml).join('');
    bindCopy();

    if (totalPages > 1) {
      paginationEl.classList.remove('hidden');
      paginationEl.classList.add('flex');
      prevBtn.disabled = currentPage <= 1;
      nextBtn.disabled = currentPage >= totalPages;
      pageInfo.textContent = `${currentPage} of ${totalPages}`;
    } else {
      paginationEl.classList.add('hidden');
    }

    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  prevBtn.addEventListener('click', () => { currentPage--; render(); updateUrl(); });
  nextBtn.addEventListener('click', () => { currentPage++; render(); updateUrl(); });

  render();
</script>
